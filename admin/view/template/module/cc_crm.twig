{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-crm" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-save"></i></button>
        <button type="button" id="btn-log" class="btn btn-info"><i class="fa-solid fa-list"></i> {{ text_log_link }}</button>
        <a href="{{ back }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div id="alert-crm"></div>
    <div id="log-panel" class="mb-3"></div>

    <div class="card">
      <div class="card-header"><i class="fa-solid fa-pencil"></i> {{ text_edit }}</div>
      <div class="card-body">
        <form id="form-crm" action="{{ save }}" method="post">
          <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item"><a class="nav-link active" href="#tab-general" data-bs-toggle="tab">{{ text_general }}</a></li>
            <li class="nav-item"><a class="nav-link" href="#tab-targets" data-bs-toggle="tab">{{ text_targets }}</a></li>
            {% if reverse_supported %}
            <li class="nav-item"><a class="nav-link" href="#tab-reverse" data-bs-toggle="tab">{{ text_reverse }}</a></li>
            {% endif %}
          </ul>
          <div class="tab-content">

            <div class="tab-pane active" id="tab-general">
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_status }}</label>
                <div class="col-sm-9"><div class="form-check form-switch form-switch-lg">
                  <input type="hidden" name="module_cc_crm_status" value="0"/>
                  <input type="checkbox" name="module_cc_crm_status" value="1" class="form-check-input"{{ status == '1' ? ' checked' : '' }}/>
                </div></div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_send_on }}</label>
                <div class="col-sm-9"><select name="module_cc_crm_send_on" class="form-select" style="max-width:280px">
                  <option value="create"{{ send_on == 'create' ? ' selected' : '' }}>{{ text_on_create }}</option>
                  <option value="status"{{ send_on == 'status' ? ' selected' : '' }}>{{ text_on_status }}</option>
                </select><div class="form-text">{{ help_send_on }}</div></div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_trigger }}</label>
                <div class="col-sm-9"><select name="module_cc_crm_trigger_status" class="form-select" style="max-width:280px">
                  {% for s in order_statuses %}
                  <option value="{{ s.order_status_id }}"{{ trigger_status == s.order_status_id ? ' selected' : '' }}>{{ s.name }}</option>
                  {% endfor %}
                </select></div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_skip_zero }}</label>
                <div class="col-sm-9"><div class="form-check form-switch form-switch-lg">
                  <input type="hidden" name="module_cc_crm_skip_zero" value="0"/>
                  <input type="checkbox" name="module_cc_crm_skip_zero" value="1" class="form-check-input"{{ skip_zero == '1' ? ' checked' : '' }}/>
                </div></div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_include_ship }}</label>
                <div class="col-sm-9"><div class="form-check form-switch form-switch-lg">
                  <input type="hidden" name="module_cc_crm_include_ship" value="0"/>
                  <input type="checkbox" name="module_cc_crm_include_ship" value="1" class="form-check-input"{{ include_ship == '1' ? ' checked' : '' }}/>
                </div></div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_retry }}</label>
                <div class="col-sm-9"><div class="form-check form-switch form-switch-lg">
                  <input type="hidden" name="module_cc_crm_retry_enabled" value="0"/>
                  <input type="checkbox" name="module_cc_crm_retry_enabled" value="1" class="form-check-input"{{ retry_enabled == '1' ? ' checked' : '' }}/>
                </div></div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_max_attempts }}</label>
                <div class="col-sm-9"><input type="number" min="1" max="50" name="module_cc_crm_max_attempts" value="{{ max_attempts }}" class="form-control" style="max-width:120px"/></div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_source }}</label>
                <div class="col-sm-9"><input type="text" name="module_cc_crm_source_label" value="{{ source_label }}" class="form-control" style="max-width:280px"/></div>
              </div>
            </div>

            <div class="tab-pane" id="tab-targets">
              {% for slug, cfg in targets %}
              <fieldset>
                <legend>{{ target_labels[slug] }}</legend>
                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label">{{ entry_enabled }}</label>
                  <div class="col-sm-9"><div class="form-check form-switch form-switch-lg">
                    <input type="hidden" name="module_cc_crm_targets[{{ slug }}][enabled]" value="0"/>
                    <input type="checkbox" name="module_cc_crm_targets[{{ slug }}][enabled]" value="1" class="form-check-input"{{ cfg.enabled == '1' ? ' checked' : '' }}/>
                  </div></div>
                </div>
                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label">{{ entry_base_url }}</label>
                  <div class="col-sm-9"><input type="text" name="module_cc_crm_targets[{{ slug }}][base_url]" value="{{ cfg.base_url }}" class="form-control"/></div>
                </div>
                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label">{{ entry_api_key }}</label>
                  <div class="col-sm-9">
                    <input type="password" name="module_cc_crm_targets[{{ slug }}][api_key]" value="" class="form-control" placeholder="{{ cfg.api_key_set ? text_secret_set : '' }}" autocomplete="new-password"/>
                    <div class="form-text">{{ help_api_key }}</div>
                  </div>
                </div>
                {% if slug == 'keycrm' %}
                <div class="row mb-3">
                  <label class="col-sm-3 col-form-label">{{ entry_source_id }}</label>
                  <div class="col-sm-9"><input type="text" name="module_cc_crm_targets[{{ slug }}][source_id]" value="{{ cfg.source_id }}" class="form-control" style="max-width:200px"/></div>
                </div>
                {% endif %}
                <div class="row mb-3">
                  <div class="col-sm-9 offset-sm-3">
                    <button type="button" class="btn btn-outline-primary btn-test" data-slug="{{ slug }}"><i class="fa-solid fa-plug"></i> {{ button_test }}</button>
                    <span class="test-result ms-2"></span>
                  </div>
                </div>
              </fieldset>
              {% endfor %}
            </div>

            {% if reverse_supported %}
            <div class="tab-pane" id="tab-reverse">
              <div class="alert alert-light border">{{ help_reverse }}</div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_reverse_enabled }}</label>
                <div class="col-sm-9"><div class="form-check form-switch form-switch-lg">
                  <input type="hidden" name="module_cc_crm_reverse_enabled" value="0"/>
                  <input type="checkbox" name="module_cc_crm_reverse_enabled" value="1" class="form-check-input"{{ reverse_enabled == '1' ? ' checked' : '' }}/>
                </div></div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_reverse_notify }}</label>
                <div class="col-sm-9"><div class="form-check form-switch form-switch-lg">
                  <input type="hidden" name="module_cc_crm_reverse_notify" value="0"/>
                  <input type="checkbox" name="module_cc_crm_reverse_notify" value="1" class="form-check-input"{{ reverse_notify == '1' ? ' checked' : '' }}/>
                </div><div class="form-text">{{ help_reverse_notify }}</div></div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_reverse_stock }}</label>
                <div class="col-sm-9"><div class="form-check form-switch form-switch-lg">
                  <input type="hidden" name="module_cc_crm_reverse_stock" value="0"/>
                  <input type="checkbox" name="module_cc_crm_reverse_stock" value="1" class="form-check-input"{{ reverse_stock == '1' ? ' checked' : '' }}/>
                </div><div class="form-text">{{ help_reverse_stock }}</div></div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_reverse_last }}</label>
                <div class="col-sm-9"><span class="form-control-plaintext">{% if reverse_last_run %}{{ reverse_last_run }} UTC{% else %}{{ text_never }}{% endif %}</span></div>
              </div>
              <div class="row mb-3">
                <label class="col-sm-3 col-form-label">{{ entry_reverse_map }}</label>
                <div class="col-sm-9">
                  <table class="table table-sm" id="reverse-map" style="max-width:640px">
                    <thead>
                      <tr>
                        <th>{{ column_keycrm_status }}</th>
                        <th>{{ column_oc_status }}</th>
                        <th style="width:1%"></th>
                      </tr>
                    </thead>
                    <tbody>
                      {% for k, v in reverse_status_map %}
                      <tr>
                        <td>
                          <select name="module_cc_crm_reverse_status_map[{{ loop.index0 }}][keycrm]" class="form-select keycrm-status">
                            <option value="{{ k }}" selected>#{{ k }}</option>
                          </select>
                        </td>
                        <td>
                          <select name="module_cc_crm_reverse_status_map[{{ loop.index0 }}][oc]" class="form-select">
                            {% for s in order_statuses %}
                            <option value="{{ s.order_status_id }}"{{ v == s.order_status_id ? ' selected' : '' }}>{{ s.name }}</option>
                            {% endfor %}
                          </select>
                        </td>
                        <td><button type="button" class="btn btn-outline-danger btn-map-remove"><i class="fa-solid fa-minus-circle"></i></button></td>
                      </tr>
                      {% endfor %}
                    </tbody>
                    <tfoot>
                      <tr>
                        <td colspan="2">
                          <button type="button" id="btn-load-statuses" class="btn btn-outline-primary"><i class="fa-solid fa-download"></i> {{ button_load_statuses }}</button>
                          <span id="statuses-result" class="ms-2"></span>
                        </td>
                        <td><button type="button" id="btn-map-add" class="btn btn-primary"><i class="fa-solid fa-plus-circle"></i></button></td>
                      </tr>
                    </tfoot>
                  </table>
                  <div class="form-text">{{ help_reverse_map }}</div>
                </div>
              </div>
            </div>
            {% endif %}

          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
// Twig html-escapes controller URLs (& -> &amp;), which is fine in href
// attributes but breaks fetch() targets — the user_token gets lost and
// OpenCart answers with the login page instead of JSON.
function ccCrmUrl(s) { return s.replace(/&amp;/g, '&'); }

document.getElementById('form-crm').addEventListener('submit', function(e) {
  e.preventDefault();
  var alertBox = document.getElementById('alert-crm');
  fetch(ccCrmUrl('{{ save }}'), { method: 'POST', body: new FormData(this) })
    .then(function(r){ return r.json(); })
    .then(function(json){
      if (json.error) { alertBox.innerHTML = '<div class="alert alert-danger">' + json.error + '</div>'; }
      else if (json.success) { alertBox.innerHTML = '<div class="alert alert-success">' + json.success + '</div>'; }
      window.scrollTo(0, 0);
    });
});

document.querySelectorAll('.btn-test').forEach(function(btn){
  btn.addEventListener('click', function(){
    var slug = this.getAttribute('data-slug');
    var out = this.parentNode.querySelector('.test-result');
    out.innerHTML = '<span class="text-muted">…</span>';
    fetch(ccCrmUrl('{{ test }}') + '&target=' + encodeURIComponent(slug))
      .then(function(r){ return r.json(); })
      .then(function(json){
        if (json.ok) { out.innerHTML = '<span class="text-success">{{ text_test_ok }}</span>'; }
        else { out.innerHTML = '<span class="text-danger">' + (json.error || 'Error') + '</span>'; }
      });
  });
});

document.getElementById('btn-log').addEventListener('click', function(){
  var panel = document.getElementById('log-panel');
  fetch(ccCrmUrl('{{ log }}')).then(function(r){ return r.text(); }).then(function(html){ panel.innerHTML = html; });
});

// --- Reverse sync: status mapping UI ---
(function(){
  var mapTable = document.getElementById('reverse-map');
  if (!mapTable) { return; }

  var tbody = mapTable.querySelector('tbody');
  var rowIndex = {{ reverse_status_map|length }};
  var keycrmStatuses = [];
  var ocOptions = '{% for s in order_statuses %}<option value="{{ s.order_status_id }}">{{ s.name|e('js') }}</option>{% endfor %}';

  function keycrmOptions(selected) {
    if (!keycrmStatuses.length) {
      return selected !== '' ? '<option value="' + selected + '" selected>#' + selected + '</option>' : '<option value=""></option>';
    }
    var html = '<option value=""></option>', found = false;
    keycrmStatuses.forEach(function(s){
      var sel = String(s.id) === String(selected);
      if (sel) { found = true; }
      html += '<option value="' + s.id + '"' + (sel ? ' selected' : '') + '>' + s.name + ' (#' + s.id + ')</option>';
    });
    if (!found && selected !== '') {
      html += '<option value="' + selected + '" selected>#' + selected + '</option>';
    }
    return html;
  }

  function bindRemove(btn) {
    btn.addEventListener('click', function(){ this.closest('tr').remove(); });
  }
  mapTable.querySelectorAll('.btn-map-remove').forEach(bindRemove);

  document.getElementById('btn-map-add').addEventListener('click', function(){
    var tr = document.createElement('tr');
    tr.innerHTML =
      '<td><select name="module_cc_crm_reverse_status_map[' + rowIndex + '][keycrm]" class="form-select keycrm-status">' + keycrmOptions('') + '</select></td>' +
      '<td><select name="module_cc_crm_reverse_status_map[' + rowIndex + '][oc]" class="form-select">' + ocOptions + '</select></td>' +
      '<td><button type="button" class="btn btn-outline-danger btn-map-remove"><i class="fa-solid fa-minus-circle"></i></button></td>';
    tbody.appendChild(tr);
    bindRemove(tr.querySelector('.btn-map-remove'));
    rowIndex++;
  });

  document.getElementById('btn-load-statuses').addEventListener('click', function(){
    var out = document.getElementById('statuses-result');
    out.innerHTML = '<span class="text-muted">…</span>';
    var fd = new FormData();
    var keyInput  = document.querySelector('[name="module_cc_crm_targets[keycrm][api_key]"]');
    var baseInput = document.querySelector('[name="module_cc_crm_targets[keycrm][base_url]"]');
    if (keyInput)  { fd.append('api_key', keyInput.value); }
    if (baseInput) { fd.append('base_url', baseInput.value); }
    fetch(ccCrmUrl('{{ statuses }}'), { method: 'POST', body: fd })
      .then(function(r){ return r.json(); })
      .then(function(json){
        if (!json.ok) { out.innerHTML = '<span class="text-danger">' + (json.error || 'Error') + '</span>'; return; }
        keycrmStatuses = json.statuses || [];
        mapTable.querySelectorAll('.keycrm-status').forEach(function(sel){
          sel.innerHTML = keycrmOptions(sel.value);
        });
        out.innerHTML = '<span class="text-success">{{ text_statuses_loaded }} (' + keycrmStatuses.length + ')</span>';
      });
  });
})();
</script>
{{ footer }}
